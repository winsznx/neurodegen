# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (keep .env.example; ignore actual secrets)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# contract build artifacts (generated by pnpm attestation:compile)
/artifacts

# internal planning + session-continuity docs (not for public consumption)
/AGENT_PROGRESS.md
/AGENTS.md
/CLAUDE.md
/DEFERRED.md
/neurodegen master.md

# internal scripts (smoke tests, audit, submission drafts)
/scripts/audit.sh
/scripts/demo-checklist.md
/scripts/smokeAttestation.ts
/scripts/smokeCommitReveal.ts
/scripts/submission

# stray draft notes (DoraHacks copy, outreach templates, anything offline)
*.txt

# editor + OS
.idea
.vscode/settings.json
Thumbs.db

# Claude Code session state (local only)
/.claude
