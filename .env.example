# ============================================================
# NeuroDegen Environment Variables
# ============================================================

# --- DGrid (Multi-model LLM gateway) ---
# Server-only | Required
DGRID_API_KEY=

# --- BYOK Keys (Cost-aware routing, optional if DGrid-only) ---
# Server-only | Optional
OPENAI_API_KEY=
# Server-only | Optional
ANTHROPIC_API_KEY=

# --- Bitquery (Four.meme event ingestion; same v2 token for REST + WS) ---
# Server-only | Required
BITQUERY_API_KEY=
# Server-only | Required
BITQUERY_WS_TOKEN=

# --- Pyth (Oracle price feeds) ---
# Server-only | Required (default: https://hermes.pyth.network)
PYTH_HERMES_URL=https://hermes.pyth.network

# --- MYX Finance (Perpetual execution via @myx-trade/sdk) ---
# Server-only | Required (default: https://api.myx.finance)
MYX_API_BASE_URL=https://api.myx.finance
# Server-only | Optional (referral/broker address; defaults to zero address)
MYX_BROKER_ADDRESS=

# --- Agent Wallet ---
# Server-only, NEVER client | Required
NEURODEGEN_AGENT_PRIVATE_KEY=

# --- BSC RPC ---
# Server-only | Required
BSC_RPC_URL=
# Server-only | Required
BSC_RPC_URL_FALLBACK=
# Server-only | Optional (dedicated RPC for log queries; defaults to https://bsc.drpc.org which allows wide eth_getLogs ranges)
BSC_LOGS_RPC_URL=

# --- Supabase (Postgres + Realtime) ---
# Server-only | Required
SUPABASE_URL=
# Client-safe (RLS-enforced) | Required
SUPABASE_ANON_KEY=
# Server-only (migrations only) | Required at build
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin ---
# Server-only | Required
ADMIN_SECRET=

# --- Public App URL (OG images, metadata links) ---
# Client-safe | Required (production default: https://neurodegen.xyz)
NEXT_PUBLIC_APP_URL=https://neurodegen.xyz

# --- Pieverse (Skill monetization via x402) ---
# Server-only | Optional (pieUSD on BSC; defaults to 0x0e63b9c287e32a05e6b9ab8ee8df88a2760225a9)
PIEVERSE_PIEUSD_ADDRESS=0x0e63b9c287e32a05e6b9ab8ee8df88a2760225a9
# Server-only | Required to accept x402 payments (address that receives pieUSD settlement)
PIEVERSE_REVENUE_ADDRESS=

# --- Attestation ---
# Server-only | Optional (set after deploying contracts/NeurodegenAttestation.sol)
ATTESTATION_CONTRACT_ADDRESS=

# --- BNB Greenfield (Receipt storage) ---
# Server-only | Optional
GREENFIELD_BUCKET=

# --- Privy (User auth + embedded wallets for copy-trade) ---
# Client-safe | Required for copy-trade
NEXT_PUBLIC_PRIVY_APP_ID=
# Server-only | Required for copy-trade
PRIVY_APP_SECRET=
# Server-only | Required for copy-trade (base64 PKCS8 P-256 private key; paired public key registered in Privy Dashboard as authorization key)
PRIVY_AUTH_PRIVATE_KEY=
# Server-only | Required for auth token verification (find in Privy Dashboard -> App Settings -> Verification key, PEM format)
PRIVY_VERIFICATION_KEY=
# Client-safe | Required for copy-trade (authorization key ID from Privy Dashboard — exposed to browser so /onboard can grant signer)
NEXT_PUBLIC_PRIVY_SIGNER_ID=

# ============================================================
# Telegram (notifications)
# ============================================================
# Server-only | Required for Telegram notifications (from @BotFather -> /newbot or /token)
TELEGRAM_BOT_TOKEN=
# Server-only | Required — the @handle of your bot (no @), used to construct t.me/<handle>?start=<token> deep-links
TELEGRAM_BOT_USERNAME=
# Server-only | Required — 32+ byte random secret. Set via `setWebhook` secret_token and validated on every webhook POST. Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# ============================================================
# Worker (Railway) coordination
# ============================================================
# Worker-only | Set to "true" in the Railway worker service env ONLY. When true, realtimeService forwards events to WEB_BROADCAST_URL instead of fanning out locally.
WORKER_MODE=
# Worker-only | URL of the web service's broadcast receiver, e.g. https://www.neurodegen.xyz/api/events/broadcast
WEB_BROADCAST_URL=
# Web-only | URL of the worker's admin HTTP server (the Railway service's public URL). Required for /api/agent/{start,stop,trigger,status,close} and the Telegram /status command to reach the real running loop. Example: https://neurodegen-worker.up.railway.app
WORKER_ADMIN_URL=

# ============================================================
# Runtime feature flags — all env-driven, safe defaults. Flip in Railway / Vercel and restart to change.
# ============================================================
# Worker-only | "true" to actually submit MYX orders. Default: false. Requires DRY_RUN_MODE=false too.
ENABLE_EXECUTION=
# Worker-only | "false" to actually sign + submit. Default: true (synthetic tx hashes). Pair with ENABLE_EXECUTION=true to go live.
DRY_RUN_MODE=
# Worker + Web | "true" to allow your OpenAI/Anthropic BYOK keys as last-resort fallback when all DGrid models fail. Default: false. Keep false to save BYOK credits during the hackathon; sponsor DGrid carries the load.
ENABLE_BYOK_ROUTING=
# Worker + Web | "true" to try funded BYOK routes before DGrid. Useful when DGrid quota is exhausted.
PREFER_BYOK_ROUTING=
# Worker + Web | "true" to skip DGrid completely and use BYOK / degraded fallbacks only.
DISABLE_DGRID_ROUTING=
# Worker-only | "false" to skip on-chain attestation emission. Default: true.
ENABLE_ATTESTATION=
# Worker + Web | "false" to disable the Pieverse /api/skill endpoint. Default: true.
ENABLE_PIEVERSE_SKILL=

# ============================================================
# Execution sizing + risk
# ============================================================
# Worker-only | Base collateral target before regime scaling. Default: 4.0
BASE_POSITION_SIZE_USD=
# Worker-only | Minimum position the gateway is allowed to auto-size down to. Default: 1.0
MIN_POSITION_SIZE_USD=
# Worker-only | Minimum BNB to keep for gas checks. Default: 0.01
GAS_BUFFER_BNB=
# Worker-only | Hard cap on collateral per position. Default: 10.0
PER_POSITION_SIZE_CAP_USD=
# Worker-only | Max fraction of wallet USDT deployable at once. Default: 1.0
MAX_TOTAL_EXPOSURE_RATIO=
# Worker-only | Max simultaneous agent positions. Default: 2
MAX_CONCURRENT_POSITIONS=
# Worker-only | Daily realized-loss stop. Default: 1.0
MAX_DAILY_LOSS_USD=
# Worker-only | Absolute leverage cap. Default: 15
MAX_LEVERAGE_HARD_CAP=
# Worker-only | Oracle/funding/slippage tuning; defaults are the current code values
ORACLE_DIVERGENCE_MAX=
OI_IMBALANCE_MAX=
FUNDING_RATE_MAX=
MAX_SLIPPAGE=
DEFAULT_TP_PERCENTAGE=
DEFAULT_SL_PERCENTAGE=
DEFAULT_LEVERAGE=

# ============================================================
# Perception retention + backfill
# ============================================================
# Worker-only | In-memory event retention. Default tracks the longest active metrics window (currently 720 minutes / 12h).
HOT_STATE_TTL_MINUTES=
# Worker-only | Four.meme startup backfill range in BSC blocks. Default: 14400 (~12h at ~3s blocks).
FOURMEME_BACKFILL_BLOCKS=
# Worker-only | Max inclusive block span per eth_getLogs call. Lower this for providers that cap log ranges (e.g. 1500 on GetBlock).
FOURMEME_GET_LOGS_MAX_RANGE=
